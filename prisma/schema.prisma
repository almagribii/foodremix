generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 0. AUTENTIKASI & SISTEM AKUN
// ==========================================
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  password      String    // bcryptjs hashed password
  name          String?
  
  // Relasi ke profile dan data lainnya
  userProfile   UserProfile?
  accounts      Account[]
  sessions      Session[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  token        String   @unique // JWT token
  expires      DateTime
  userAgent    String?
  ipAddress    String?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  type      String   // "EMAIL_VERIFY" atau "PASSWORD_RESET"
  expires   DateTime
  
  createdAt DateTime @default(now())

  @@unique([email, type])
}

model UserProfile {
  id                  String               @id @default(cuid())
  userId              String               @unique
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  nickname            String
  dailyBudgetTarget   Float                @default(30000.0)
  medicalConditions   String[]             // e.g., ["maag", "hipertensi"]
  allergies           String[]             // e.g., ["seafood", "laktosa"]

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  remixHistories      RemixHistory[]
  pickerHistories     RemixPicker[]        
  wellnessJournals    WellnessJournal[]
  notificationSetting NotificationSetting?
  notificationLogs    NotificationLog[]
  
  @@index([userId])
}

// ==========================================
// 2. LOG MASAK AI (DASHBOARD STATS & MENU HISTORY)
// ==========================================
model RemixHistory {
  id              String       @id @default(cuid())
  userId          String
  user            UserProfile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipeName      String       
  ingredientsUsed String[]     
  moneySaved      Float        
  carbonPrevented Float        
  cookedAt        DateTime     @default(now())

  @@index([userId])
}

// ==========================================
// 3. BARU: FITUR HULU - ASISTEN BELANJA PINTAR (REMIX PICKER)
// ==========================================
model RemixPicker {
  id               String       @id @default(cuid())
  userId           String
  user             UserProfile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Data Hasil Ekstraksi & Inspeksi AI
  itemName         String       // Nama bahan pangan hasil scan, e.g., "Mangga Arumanis"
  status           String       // Status Engine Validasi Kuliner, e.g., "VALID" atau "INVALID"
  verdict          String       // Ringkasan keputusan kelayakan, e.g., "LAYAK BELI (FRESH)" atau "CARI YANG LAIN"
  expectedLifespan String       // Estimasi daya tahan, e.g., "4-5 Days"
  
  // Data Detail Konten Struktural (Disimpan dalam Array Teks)
  analysisDetails  String[]     // Poin-poin visual analisis kesegaran kulit/tekstur dari AI
  storageBlueprint String[]     // Poin-poin instruksi mutlak teknik penyimpanan pasca-pasar
  
  scannedAt        DateTime     @default(now())

  @@index([userId])
}

// ==========================================
// 4. BUKU HARIAN KESEHATAN (WELLNESS JOURNAL + AI INSIGHT)
// ==========================================
model WellnessJournal {
  id               String       @id @default(cuid())
  userId           String
  user             UserProfile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  date             DateTime     @default(now())
  
  userMood         String       
  foodEaten        String       
  userStory        String       
  
  aiInsight        String       
  healthScore      Int          
  
  createdAt        DateTime     @default(now())

  @@index([userId])
}

// ==========================================
// 5. SISTEM NOTIFIKASI DATA-DRIVEN (ANTI-SPAM)
// ==========================================
model NotificationSetting {
  id                  String       @id @default(cuid())
  userId              String       @unique
  user                UserProfile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  dinnerReminderTime  String       @default("17:30") 
  journalReminderTime String       @default("21:00") 
  
  lastBudgetAlert     DateTime?
  lastWellnessAlert   DateTime?

  updatedAt           DateTime     @updatedAt
}

model NotificationLog {
  id          String       @id @default(cuid())
  userId      String
  user        UserProfile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String       
  message     String       
  type        String       // "BUDGET", "WELLNESS", atau "PICKER_ALERT"
  isRead      Boolean      @default(false)
  createdAt   DateTime     @default(now())

  @@index([userId])
}