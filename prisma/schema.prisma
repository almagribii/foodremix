
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 0. AUTENTIKASI & SISTEM AKUN
// ==========================================
model User {
  id            String  @id @default(cuid())
  email         String  @unique
  emailVerified DateTime?
  password      String  // bcryptjs hashed password
  name          String?
  
  // Relasi ke profile dan data lainnya
  userProfile   UserProfile?
  accounts      Account[]
  sessions      Session[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Account {
  id            String  @id @default(cuid())
  userId        String
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // OAuth provider (google, github, dll)
  provider      String
  providerAccountId String
  refresh_token String?  @db.Text
  access_token  String?  @db.Text
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String?  @db.Text
  session_state String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  token        String   @unique // JWT token
  expires      DateTime
  userAgent    String?
  ipAddress    String?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  type      String   // "EMAIL_VERIFY" atau "PASSWORD_RESET"
  expires   DateTime
  
  createdAt DateTime @default(now())

  @@unique([email, type])
}

// ==========================================
// 1. DATA PENGGUNA, PROTEKSI MEDIS & LOKASI ASTRAL
// ==========================================
model UserProfile {
  id                  String               @id @default(cuid())
  userId              String               @unique
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  nickname            String
  dailyBudgetTarget   Float                @default(30000.0) // Target hemat harian pengguna
  medicalConditions   String[]             // Array riwayat penyakit, e.g., ["maag", "hipertensi"]
  allergies           String[]             // Array alergi makanan, e.g., ["seafood", "laktosa"]
  
  // Geolocation umum pengguna saat registrasi (untuk komparasi radius awal)
  latitude            Float?
  longitude           Float?
  generalLocation     String               // Nama daerah teks, e.g., "Kec. Siman, Ponorogo" - WAJIB

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  // Relasi Entitas
  remixHistories      RemixHistory[]
  wellnessJournals    WellnessJournal[]
  communityPosts      CommunityPost[]
  postRequests        PostRequest[]
  notificationSetting NotificationSetting?
  notificationLogs    NotificationLog[]
  
  @@index([userId])
}

// ==========================================
// 2. LOG MASAK AI (DASHBOARD STATS & MENU HISTORY)
// ==========================================
model RemixHistory {
  id              String       @id @default(cuid())
  userId          String
  user            UserProfile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipeName      String       // Judul Menu Kreatif hasil racikan Gemini AI
  ingredientsUsed String[]     // Bahan baku yang digunakan pada sesi masak ini
  moneySaved      Float        // Nominal uang yang berhasil dihemat (Rp)
  carbonPrevented Float        // Nominal emisi CO2 yang dicegah (Kg)
  cookedAt        DateTime     @default(now())

  @@index([userId])
}

// ==========================================
// 3. BUKU HARIAN KESEHATAN (WELLNESS JOURNAL + AI INSIGHT)
// ==========================================
model WellnessJournal {
  id               String       @id @default(cuid())
  userId           String
  user             UserProfile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  date             DateTime     @default(now())
  
  // Input Keseharian dari Pengguna
  userMood         String       // Mood harian: "LELAH", "STRES", "HAPPY", dll.
  foodEaten        String       // Catatan makanan yang masuk hari ini
  userStory        String       // Cerita curhat kondisi fisik/mental harian
  
  // Output Evaluasi dari Gemini AI
  aiInsight        String       // Respons empati, solusi gizi, dan tips kesehatan dari AI
  healthScore      Int          // Skala 1-100 tingkat kepatuhan asupan terhadap penyakit user
  
  createdAt        DateTime     @default(now())

  @@index([userId])
}

// ==========================================
// 4. HUB P2P HUB BERBAGI & PATUNGAN (REMIX SHARE)
// ==========================================
model CommunityPost {
  id          String        @id @default(cuid())
  userId      String
  user        UserProfile   @relation(fields: [userId], references: [id], onDelete: Cascade)
  postType    String        // Jenis postingan: "DONASI" (bagi bahan) atau "PATUNGAN" (masak bareng)
  title       String        // e.g., "Kelebihan Telur Ayam 5 Butir" atau "Patungan Bikin Sup Ayam"
  description String        // Detail deskripsi info (tanpa membocorkan alamat spesifik)
  budgetInfo  Float?        // Nominal uang jika open patungan belanja belanja
  
  // Koordinat postingan saat dibuat untuk hitung jarak relatif
  postLat     Float
  postLng     Float
  
  isCompleted Boolean       @default(false) // Menjadi true jika proses serah terima sudah selesai
  createdAt   DateTime      @default(now())

  // Relasi ke tabel pelamar antrean
  requests    PostRequest[]

  @@index([userId])
}

// ==========================================
// 5. SISTEM VALIDASI PERSETUJUAN & SHARE LOCK PRIVAT
// ==========================================
model PostRequest {
  id         String        @id @default(cuid())
  postId     String
  post       CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId     String        // ID User yang mengajukan permintaan (penerima)
  user       UserProfile   @relation(fields: [userId], references: [id], onDelete: Cascade)
  status     String        @default("PENDING") // Status: "PENDING", "ACCEPTED", atau "REJECTED"
  
  // Lokasi Spesifik / Share Lock Penjemputan (Baru terisi jika status dikonfirmasi "ACCEPTED")
  pickupLat  Float?
  pickupLng  Float?

  createdAt  DateTime      @default(now())

  @@index([postId])
  @@index([userId])
}

// ==========================================
// 6. SISTEM NOTIFIKASI DATA-DRIVEN (ANTI-SPAM)
// ==========================================
model NotificationSetting {
  id                  String       @id @default(cuid())
  userId              String       @unique
  user                UserProfile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  dinnerReminderTime  String       @default("17:30") // Jam kritis mikir makan malam / tanggal tua
  journalReminderTime String       @default("21:00") // Jam ngisi jurnal evaluasi malam
  
  lastBudgetAlert     DateTime?
  lastWellnessAlert   DateTime?

  updatedAt           DateTime     @updatedAt
}

model NotificationLog {
  id          String       @id @default(cuid())
  userId      String
  user        UserProfile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String       // e.g., "Kantong Kritis! 🚨" atau "Bahanmu Diklaim! 🥳"
  message     String       // Isi pesan notifikasi
  type        String       // Kategori pemicu: "BUDGET", "WELLNESS", atau "SHARE_HANDSHAKE"
  isRead      Boolean      @default(false)
  createdAt   DateTime     @default(now())

  @@index([userId])
}